# ══════════════════════════════════════════════
# SkillMint — Environment Variables
# Copy to .env and fill in all values
# ══════════════════════════════════════════════

# ─── Wallet ───────────────────────────────────
# Fuji testnet wallet — NEVER use a mainnet wallet here
DEPLOYER_PRIVATE_KEY=

# Get Fuji AVAX: https://faucet.avax.network

# ─── Contracts (filled automatically by deploy.sh) ───
REGISTRY_ADDRESS=
PAYMENT_ADDRESS=
LICENSE_ADDRESS=
TREASURY_ADDRESS=

# ─── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Pinata IPFS ──────────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ─── Supabase ─────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── WalletConnect ────────────────────────────
WALLETCONNECT_PROJECT_ID=

# ─── Server ───────────────────────────────────
PORT=3001
NETWORK=fuji
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
